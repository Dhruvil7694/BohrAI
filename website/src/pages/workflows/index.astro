---
import { getCollection } from "astro:content"
import Layout from "@/layouts/main.astro"
import WorkflowCard from "@/components/WorkflowCard.astro"

const entries = await getCollection("workflowPages")
entries.sort((a, b) => a.data.order - b.data.order)

const pipelines = entries.filter((e) => e.data.category === "pipeline")
const modules = entries.filter((e) => e.data.category === "module")
---

<Layout
  title="Workflows - Bohr AI"
  description="Research pipelines and workflow modules: slash commands, flow diagrams, and deep-dive pages."
  active="explore"
>
  <div class="page-gutter-x pb-16 pt-10 sm:pt-12">
    <header class="mb-12 max-w-3xl">
      <p class="hub-kicker mb-2">- EXPLORE | WORKFLOWS</p>
      <h1
        class="mt-6 text-balance font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(1.85rem,3.8vw,2.75rem)] font-normal italic leading-[1.12] tracking-tight text-[var(--bohr-shell-fg)]"
      >
        Workflows
      </h1>
      <p class="mt-5 max-w-3xl font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-neutral-700 sm:text-[13px] dark:text-neutral-300">
        Each card opens a detail page with a flow diagram and short guide. Slash commands run in the REPL;
        <code class="rounded-[2px] border border-[color:var(--bohr-shell-border)] bg-muted/50 px-1.5 py-0.5 text-[11px] text-[var(--bohr-shell-fg)]">bohr ...</code>
        maps to the same pipeline from the shell.
      </p>
    </header>

    <div class="mb-8">
      <label class="sr-only" for="workflow-filter">Filter workflows</label>
      <input
        id="workflow-filter"
        class="wf-hub-search"
        type="search"
        placeholder="Filter by name, slash command, or keyword..."
        autocomplete="off"
      />
    </div>

    <section class="mb-14" aria-labelledby="pipelines-heading">
      <p class="wf-hub-kicker">- PIPELINES</p>
      <h2 id="pipelines-heading" class="wf-hub-section-title">End-to-end pipelines</h2>
      <p class="mb-6 max-w-2xl font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-neutral-600 dark:text-neutral-400">
        Full research flows - literature, paper, audit, replication, and more.
      </p>
      <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4" id="workflow-grid-pipelines">
        {
          pipelines.map((e) => {
            const blob = `${e.data.title} ${e.data.summary} ${e.data.slashCommand} ${e.data.cliName} pipeline`.toLowerCase()
            return (
              <li data-wf-card data-search={blob}>
                <WorkflowCard
                  title={e.data.title}
                  summary={e.data.summary}
                  href={`/workflows/${e.slug}`}
                  slashCommand={e.data.slashCommand}
                  category="pipeline"
                />
              </li>
            )
          })
        }
      </ul>
    </section>

    <section aria-labelledby="modules-heading">
      <p class="wf-hub-kicker">- MODULES</p>
      <h2 id="modules-heading" class="wf-hub-section-title">Workflow modules</h2>
      <p class="mb-6 max-w-2xl font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-neutral-600 dark:text-neutral-400">
        Focused stages you can compose - hypothesis, graphs, citation checks, iteration, and more.
      </p>
      <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4" id="workflow-grid-modules">
        {
          modules.map((e) => {
            const blob = `${e.data.title} ${e.data.summary} ${e.data.slashCommand} ${e.data.cliName} module`.toLowerCase()
            return (
              <li data-wf-card data-search={blob}>
                <WorkflowCard
                  title={e.data.title}
                  summary={e.data.summary}
                  href={`/workflows/${e.slug}`}
                  slashCommand={e.data.slashCommand}
                  category="module"
                />
              </li>
            )
          })
        }
      </ul>
    </section>

    <p class="mt-14 text-center text-sm text-muted-foreground">
      See how everything connects in{" "}
      <a class="font-medium text-primary underline underline-offset-2" href="/how-it-works">How it works</a>
      {" | "}
      <a class="font-medium text-primary underline underline-offset-2" href="/docs/reference/slash-commands">Slash command reference</a>
    </p>
  </div>

  <script>
    import { gsap } from "gsap"

    type WorkflowMotionWindow = Window & {
      __bohrWorkflowMotionBound?: boolean
      __bohrWorkflowMotionCleanup?: () => void
      __bohrWorkflowMotionFrame?: number
    }

    const workflowMotionWindow = window as WorkflowMotionWindow

    function clearCardStyles(cards: HTMLElement[]) {
      cards.forEach((card) => {
        card.removeAttribute("style")
      })
    }

    function initWorkflowMotion() {
      workflowMotionWindow.__bohrWorkflowMotionCleanup?.()
      workflowMotionWindow.__bohrWorkflowMotionCleanup = undefined

      const cards = gsap.utils.toArray<HTMLElement>(".wf-card")
      if (cards.length === 0) return

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        clearCardStyles(cards)
        return
      }

      let tween: gsap.core.Tween | undefined
      const frame = window.requestAnimationFrame(() => {
        tween = gsap.fromTo(
          cards,
          { autoAlpha: 0, y: 18 },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.45,
            ease: "power2.out",
            overwrite: true,
            clearProps: "opacity,visibility,transform",
          },
        )
      })
      workflowMotionWindow.__bohrWorkflowMotionFrame = frame

      workflowMotionWindow.__bohrWorkflowMotionCleanup = () => {
        if (workflowMotionWindow.__bohrWorkflowMotionFrame) {
          window.cancelAnimationFrame(workflowMotionWindow.__bohrWorkflowMotionFrame)
          workflowMotionWindow.__bohrWorkflowMotionFrame = undefined
        }
        tween?.kill()
        clearCardStyles(cards)
      }
    }

    initWorkflowMotion()

    if (!workflowMotionWindow.__bohrWorkflowMotionBound) {
      document.addEventListener("astro:page-load", initWorkflowMotion)
      document.addEventListener("astro:after-swap", initWorkflowMotion)
      workflowMotionWindow.__bohrWorkflowMotionBound = true
    }
  </script>

  <script is:inline>
    ;(function () {
      function bind() {
        var input = document.getElementById("workflow-filter")
        if (!input) return
        function run() {
          var q = (input.value || "").toLowerCase().trim()
          document.querySelectorAll("[data-wf-card]").forEach(function (el) {
            var s = (el.getAttribute("data-search") || "").toLowerCase()
            el.style.display = !q || s.indexOf(q) !== -1 ? "" : "none"
          })
        }
        input.addEventListener("input", run)
      }
      bind()
      document.addEventListener("astro:after-swap", bind)
    })()
  </script>
</Layout>
