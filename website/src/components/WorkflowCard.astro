---
interface Props {
  title: string
  summary: string
  href: string
  slashCommand: string
  category: "pipeline" | "module"
}

const { title, summary, href, slashCommand, category } = Astro.props
const kind = category === "pipeline" ? "Pipeline" : "Module"
---

<a
  href={href}
  class="wf-card group relative flex h-full flex-col overflow-hidden rounded-2xl border border-border/45 bg-gradient-to-b from-card/95 via-card/80 to-muted/15 p-6 font-sans shadow-[0_12px_40px_-16px_rgba(0,0,0,0.65)] ring-1 ring-border/30 transition-[border-color,box-shadow,transform] duration-200 ease-out hover:-translate-y-1 hover:border-primary/35 hover:shadow-[0_20px_44px_-22px_rgba(0,0,0,0.72)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
>
  <span
    data-wf-card-glow
    class="pointer-events-none absolute inset-x-6 top-0 h-24 rounded-full bg-[radial-gradient(circle_at_top,rgba(34,197,94,0.2),transparent_72%)] opacity-0 blur-2xl transition-opacity duration-200 group-hover:opacity-100 dark:bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.22),transparent_72%)]"
    aria-hidden="true"
  />
  <span
    data-wf-card-grid
    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100"
    aria-hidden="true"
  >
    <span class="absolute inset-x-0 top-6 border-t border-dashed border-border/45" />
    <span class="absolute inset-y-0 right-7 border-r border-dashed border-border/35" />
  </span>

  <div class="relative z-[1] flex h-full flex-col">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span
        class:list={[
          "rounded-full border px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider",
          category === "pipeline"
            ? "border-primary/35 bg-primary/10 text-primary"
            : "border-border bg-muted/50 text-muted-foreground",
        ]}
      >
        {kind}
      </span>
      <code
        data-wf-card-chip
        class="rounded-md border border-border/60 bg-background/90 px-2 py-1 font-mono text-[11px] text-muted-foreground transition-[border-color,color] duration-200 group-hover:border-primary/30 group-hover:text-foreground"
        >{slashCommand}</code
      >
    </div>

    <div class="flex flex-1 flex-col">
      <div class="mb-4 flex items-start justify-between gap-3">
        <h2
          data-wf-card-title
          class="text-lg font-semibold tracking-tight text-foreground transition-colors duration-200 group-hover:text-primary"
        >
          {title}
        </h2>
        <span
          class="shrink-0 rounded-full border border-border/60 px-2 py-0.5 font-[family-name:var(--font-cli)] text-[10px] uppercase tracking-[0.16em] text-muted-foreground"
        >
          {kind}
        </span>
      </div>

      <p class="flex-1 text-sm leading-relaxed text-muted-foreground">{summary}</p>
    </div>

    <span
      data-wf-card-cta
      class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-colors duration-200"
    >
      View workflow
      <svg data-wf-card-arrow class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </span>
  </div>
</a>
