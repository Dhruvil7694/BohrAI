---
interface Props {
  variant?: "default" | "cli"
}

const { variant = "default" } = Astro.props
const cli = variant === "cli"
---

<footer
  class:list={[
    cli ? "border-t border-[#262626] bg-[#050505]" : "border-t border-border/60",
  ]}
>
  <div
    class:list={[
      "mx-auto flex w-full max-w-none flex-col items-center justify-between gap-3 px-3 py-6 sm:flex-row sm:px-5 md:px-8 lg:px-10 xl:px-12",
      cli ? "font-[family-name:var(--font-cli)] text-xs text-[#737373]" : "",
    ]}
  >
    <p class:list={[cli ? "" : "text-sm text-muted-foreground"]}>
      &copy; {new Date().getFullYear()} Bohr — research-first CLI on Pi.
    </p>
    <div class:list={["flex items-center gap-4", cli ? "text-[#a3a3a3]" : "text-sm"]}>
      <a
        href="/docs"
        class:list={[
          cli
            ? "transition-colors hover:text-[#fafafa] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[#737373]"
            : "text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background",
        ]}>Documentation</a
      >
      <a
        href="/docs/getting-started/installation"
        class:list={[
          cli
            ? "transition-colors hover:text-[#fafafa] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[#737373]"
            : "text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background",
        ]}>Installation</a
      >
    </div>
  </div>
</footer>
