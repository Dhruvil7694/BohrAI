---
import { BOHR_SEMVER } from "@/data/bohr-root-version"
import { BOHR_GITHUB_REPO_URL } from "@/data/site-urls"
import NavIcon from "@/components/NavIcon.astro"

interface Props {
  /** Reserved for future active-route styling; layout still passes it. */
  active?: "home" | "docs" | "explore" | "prototype"
}
const path = Astro.url.pathname

function match(href: string): boolean {
  if (href === "/") return path === "/"
  return path === href || path.startsWith(`${href}/`)
}

const exploreLinks = [
  { href: "/", label: "home", icon: "home" as const },
  { href: "/prototype", label: "prototype", icon: "prototype" as const },
  { href: "/agents", label: "agents", icon: "agents" as const },
  { href: "/workflows", label: "workflows", icon: "workflows" as const },
  { href: "/how-it-works", label: "process", icon: "process" as const },
] as const

const onCommands = path.includes("/reference/slash-commands")
const onDocsHub = path === "/docs" || path.startsWith("/docs/")
const onInstall = path.includes("/getting-started/installation")

function navLinkClass(activeLink: boolean): string {
  return activeLink
    ? "bg-black/[0.065] text-[var(--bohr-shell-fg)] dark:bg-white/[0.08] dark:text-[#fafafa]"
    : "text-neutral-600 transition-colors duration-200 hover:text-[var(--bohr-shell-fg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/15 dark:text-[#9a9a9a] dark:hover:text-[#fafafa] dark:focus-visible:ring-white/20"
}

function utilityLinkClass(activeLink: boolean): string {
  return activeLink
    ? "bg-black/[0.065] text-[var(--bohr-shell-fg)] dark:bg-white/[0.08] dark:text-[#fafafa]"
    : "text-neutral-600 transition-colors duration-200 hover:text-[var(--bohr-shell-fg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/15 dark:text-[#9a9a9a] dark:hover:text-[#fafafa] dark:focus-visible:ring-white/20"
}

function installClass(): string {
  return onInstall
    ? "bg-[var(--bohr-shell-fg)] text-[var(--bohr-shell-bg)] dark:bg-[#fafafa] dark:text-black"
    : "border border-black/10 text-[var(--bohr-shell-fg)] transition-colors duration-200 hover:bg-black/[0.045] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/15 dark:border-white/10 dark:text-[#fafafa] dark:hover:bg-white/[0.06] dark:focus-visible:ring-white/20"
}

function linkIconTone(activeLink: boolean, accent = false): string {
  if (accent && activeLink) return "text-current"
  return activeLink
    ? "text-[var(--bohr-shell-fg)] dark:text-[#fafafa]"
    : "text-neutral-500 transition-colors group-hover:text-[var(--bohr-shell-fg)] dark:text-[#8a8a8a] dark:group-hover:text-[#fafafa]"
}
---

<nav class="fixed inset-x-0 top-0 z-50 border-b border-black/10 bg-[color-mix(in_oklab,var(--bohr-shell-bg)_92%,white_8%)]/95 backdrop-blur-md dark:border-white/10 dark:bg-[#050505]/92" aria-label="Primary">
  <div class="flex min-h-[4.5rem] w-full items-center gap-3 px-4 py-3 font-[family-name:var(--font-cli)] sm:px-6 lg:px-8 xl:px-10">
    <a href="/" class="inline-flex shrink-0 items-center gap-3 no-underline">
      <span class="text-[13px] font-bold uppercase tracking-[0.08em] text-[var(--bohr-shell-fg)]">BOHR/AI</span>
      <span class="hidden text-[10px] uppercase tracking-[0.18em] text-neutral-500 dark:text-[#7f7f7f] md:block">
        Research shell | v{BOHR_SEMVER}
      </span>
    </a>

    <div class="ml-auto flex min-w-0 flex-1 items-center justify-end gap-2">
      <div class="flex min-w-0 flex-1 justify-end overflow-x-auto [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="flex min-w-max items-center gap-1 sm:gap-1.5">
          {
            exploreLinks.map((link) => {
              const on = match(link.href)
              return (
                <a
                  href={link.href}
                  class:list={[navLinkClass(on), "group inline-flex h-9 shrink-0 items-center gap-2 rounded-md px-3 text-[12px] font-medium lowercase"]}
                  aria-current={on ? "page" : undefined}
                >
                  <NavIcon name={link.icon} class={linkIconTone(on)} />
                  <span>{link.label}</span>
                </a>
              )
            })
          }
          <a
            href="/docs/reference/slash-commands"
            class:list={[utilityLinkClass(onCommands), "group inline-flex h-9 shrink-0 items-center gap-2 rounded-md px-3 text-[12px] font-medium lowercase"]}
            aria-current={onCommands ? "page" : undefined}
          >
            <NavIcon name="commands" class={linkIconTone(onCommands)} />
            <span>commands</span>
          </a>
          <a
            href="/docs"
            class:list={[utilityLinkClass(onDocsHub && !onCommands), "group inline-flex h-9 shrink-0 items-center gap-2 rounded-md px-3 text-[12px] font-medium lowercase"]}
            aria-current={onDocsHub && !onCommands ? "page" : undefined}
          >
            <NavIcon name="docs" class={linkIconTone(onDocsHub && !onCommands)} />
            <span>docs</span>
          </a>
          <a
            href={BOHR_GITHUB_REPO_URL}
            class:list={[utilityLinkClass(false), "group inline-flex h-9 shrink-0 items-center gap-2 rounded-md px-3 text-[12px] font-medium lowercase"]}
            target="_blank"
            rel="noopener noreferrer"
          >
            <NavIcon name="github" class={linkIconTone(false)} />
            <span>github</span>
          </a>
          <a
            href="/docs/getting-started/installation"
            class:list={[installClass(), "group inline-flex h-9 shrink-0 items-center gap-2 rounded-md px-3.5 text-[12px] font-semibold lowercase"]}
            aria-current={onInstall ? "page" : undefined}
          >
            <NavIcon name="install" class={linkIconTone(onInstall, true)} />
            <span>install</span>
          </a>
        </div>
      </div>

      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle relative inline-flex size-9 shrink-0 items-center justify-center rounded-md border border-black/10 text-[var(--bohr-shell-fg)] transition-colors duration-200 hover:bg-black/[0.045] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/15 dark:border-white/10 dark:text-[#fafafa] dark:hover:bg-white/[0.06] dark:focus-visible:ring-white/20"
        aria-label="Toggle theme"
        aria-pressed="false"
        data-theme="light"
      >
        <span class="theme-toggle-icon theme-toggle-icon-sun">
          <NavIcon name="sun" class="size-[0.95rem]" />
        </span>
        <span class="theme-toggle-icon theme-toggle-icon-moon">
          <NavIcon name="moon" class="size-[0.95rem]" />
        </span>
      </button>
    </div>
  </div>
</nav>

<style>
  .theme-toggle-icon {
    position: absolute;
    display: inline-flex;
    transition:
      opacity 240ms ease,
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-toggle-icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-toggle-icon-moon {
    opacity: 0;
    transform: rotate(-70deg) scale(0.7);
  }

  .theme-toggle[data-theme="dark"] .theme-toggle-icon-sun {
    opacity: 0;
    transform: rotate(70deg) scale(0.7);
  }

  .theme-toggle[data-theme="dark"] .theme-toggle-icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle-icon {
      transition: none;
    }
  }
</style>

<script is:inline>
  const THEME_SWAP_LISTENER_KEY = "__bohrThemeSwapListenerBound"

  function getStoredTheme() {
    try {
      return localStorage.getItem("theme")
    } catch {
      return null
    }
  }

  function setStoredTheme(theme) {
    try {
      localStorage.setItem("theme", theme)
    } catch {
      // Ignore storage errors (e.g. private mode restrictions).
    }
  }

  function prefersDarkTheme() {
    try {
      return window.matchMedia("(prefers-color-scheme: dark)").matches
    } catch {
      return false
    }
  }

  function applyStoredTheme() {
    const theme = getStoredTheme()
    if (theme === "dark" || (!theme && prefersDarkTheme())) {
      document.documentElement.classList.add("dark")
    } else {
      document.documentElement.classList.remove("dark")
    }
  }

  function updateThemeToggle() {
    const themeToggle = document.getElementById("theme-toggle")
    const isDark = document.documentElement.classList.contains("dark")
    if (themeToggle) {
      themeToggle.setAttribute("aria-pressed", isDark ? "true" : "false")
      themeToggle.setAttribute("data-theme", isDark ? "dark" : "light")
    }
  }

  function setupThemeToggle() {
    applyStoredTheme()
    updateThemeToggle()

    const btn = document.getElementById("theme-toggle")
    if (!btn) return
    if (btn.dataset.bound === "true") return

    btn.dataset.bound = "true"
    btn.addEventListener("click", function () {
      document.documentElement.classList.toggle("dark")
      const isDark = document.documentElement.classList.contains("dark")
      setStoredTheme(isDark ? "dark" : "light")
      updateThemeToggle()
    })
  }

  setupThemeToggle()

  if (!window[THEME_SWAP_LISTENER_KEY]) {
    window[THEME_SWAP_LISTENER_KEY] = true
    document.addEventListener("astro:after-swap", function () {
      setupThemeToggle()
    })
  }
</script>
