---
import Layout from "@/layouts/main.astro"

const tiles = [
  {
    title: "Agents",
    description: "Every bundled agent, what it does, and which workflows call it.",
    href: "/agents",
    hint: "researcher · reviewer · writer · …",
  },
  {
    title: "Workflows",
    description: "Slash-command pipelines from /deepresearch to /visuals — pick by outcome.",
    href: "/workflows",
    hint: "/lit · /visuals · /paper · …",
  },
  {
    title: "Visuals",
    description: "Charts, source-linked tables, and conceptual image assets with provider setup.",
    href: "/workflows/visuals",
    hint: "charts · tables · image models",
  },
  {
    title: "Process",
    description: "End-to-end flow: install → REPL → orchestration → artifacts, with diagrams.",
    href: "/how-it-works",
    hint: "step-by-step · diagrams",
  },
  {
    title: "Documentation",
    description: "Full prose docs: setup, templates, tools, CLI & slash reference.",
    href: "/docs",
    hint: "guides & reference",
  },
  {
    title: "Slash commands",
    description: "Alphabetical command reference for the REPL.",
    href: "/docs/reference/slash-commands",
    hint: "/help in session",
  },
  {
    title: "Installation",
    description: "Bootstrap Bohr on your machine and configure keys.",
    href: "/docs/getting-started/installation",
    hint: "quick start",
  },
] as const
---

<Layout title="Explore Bohr AI" description="Agents, workflows, process maps, and docs — organized for fast navigation." active="explore">
  <div class="page-gutter-x pb-20 pt-10 sm:pt-12">
    <header class="mb-12 w-full max-w-none">
      <p class="hub-kicker mb-2">— 00 · INDEX</p>
      <h1
        class="mt-6 font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(1.85rem,3.8vw,2.75rem)] font-normal italic leading-[1.12] tracking-tight text-[var(--bohr-shell-fg)]"
      >
        Explore
      </h1>
      <p class="mt-5 max-w-3xl font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-neutral-700 sm:text-[13px] dark:text-neutral-300">
        Choose how you want to learn Bohr: browse <strong class="font-medium text-[var(--bohr-shell-fg)]">agents</strong> and{" "}
        <strong class="font-medium text-[var(--bohr-shell-fg)]">workflows</strong>, read the{" "}
        <strong class="font-medium text-[var(--bohr-shell-fg)]">process</strong> overview with diagrams, or jump into full{" "}
        <strong class="font-medium text-[var(--bohr-shell-fg)]">documentation</strong>.
      </p>
    </header>

    <ul class="grid gap-4 sm:grid-cols-2">
      {
        tiles.map((t) => (
          <li>
            <a href={t.href} class="hub-card group h-full no-underline">
              <span class="font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-xl font-normal italic leading-snug text-[var(--bohr-shell-fg)] transition-colors group-hover:text-[var(--bohr-shell-accent-serif)]">
                {t.title}
              </span>
              <span class="text-sm leading-relaxed text-muted-foreground">{t.description}</span>
              <span class="mt-auto font-[family-name:var(--font-cli)] text-[11px] uppercase tracking-[0.12em] text-neutral-500 transition-colors group-hover:text-[var(--bohr-shell-fg)] dark:text-neutral-400">
                {t.hint}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
