  <script>
    import { gsap } from "gsap"
    import { ScrollTrigger } from "gsap/ScrollTrigger"

    gsap.registerPlugin(ScrollTrigger)

    type HomeMotionWindow = Window & {
      __bohrHomeMotionBound?: boolean
      __bohrHomeMotionCleanup?: () => void
    }

    const homeMotionWindow = window as HomeMotionWindow

    function clearMotion(root: Element) {
      root
        .querySelectorAll<HTMLElement>(
          "[data-gsap-hero-top] > *, [data-gsap-hero-title] > *, [data-gsap-hero-meta], [data-gsap-hero-rule], [data-gsap-hero-copy], [data-gsap-cta], [data-gsap-reveal], [data-gsap-stagger-item]",
        )
        .forEach((element) => element.removeAttribute("style"))
    }

    function initHomepageMotion() {
      homeMotionWindow.__bohrHomeMotionCleanup?.()
      homeMotionWindow.__bohrHomeMotionCleanup = undefined

      const root = document.querySelector(".cli-home-root")
      if (!root) return

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        clearMotion(root)
        return
      }

      const mm = gsap.matchMedia()
      const revealTargets = gsap
        .utils.toArray<HTMLElement>("[data-gsap-reveal]", root)
        .filter((target) => !target.hasAttribute("data-gsap-scrolltrigger"))
      let observer: IntersectionObserver | undefined

      const ctx = gsap.context(() => {
        const intro = gsap.timeline({
          defaults: { duration: 0.7, ease: "power3.out", overwrite: "auto" },
        })

        intro
          .from("[data-gsap-hero-top] > *", {
            autoAlpha: 0,
            y: 18,
            stagger: 0.07,
          })
          .from(
            "[data-gsap-hero-title] > *",
            {
              autoAlpha: 0,
              yPercent: 20,
              stagger: 0.1,
              duration: 0.95,
            },
            "-=0.28",
          )
          .from(
            "[data-gsap-hero-meta], [data-gsap-hero-rule], [data-gsap-hero-copy]",
            {
              autoAlpha: 0,
              y: 22,
              stagger: 0.08,
            },
            "-=0.45",
          )
          .from(
            "[data-gsap-cta]",
            {
              autoAlpha: 0,
              y: 16,
              stagger: 0.1,
              duration: 0.55,
            },
            "-=0.35",
          )

        observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return

              const target = entry.target as HTMLElement
              observer?.unobserve(target)

              const staggerItems = target.querySelectorAll<HTMLElement>("[data-gsap-stagger-item]")

              if (staggerItems.length > 0) {
                gsap.fromTo(
                  staggerItems,
                  { autoAlpha: 0, y: 28 },
                  {
                    autoAlpha: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power3.out",
                    stagger: 0.08,
                    clearProps: "opacity,visibility,transform",
                  },
                )
                return
              }

              gsap.fromTo(
                target,
                { autoAlpha: 0, y: 32 },
                {
                  autoAlpha: 1,
                  y: 0,
                  duration: 0.9,
                  ease: "power3.out",
                  clearProps: "opacity,visibility,transform",
                },
              )
            })
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -12% 0px",
          },
        )

        revealTargets.forEach((target) => observer?.observe(target))

        const sessionSection = root.querySelector<HTMLElement>('[data-gsap-scrolltrigger="session"]')
        const sessionShell = root.querySelector<HTMLElement>("[data-gsap-session-shell]")
        const sessionBody = root.querySelector<HTMLElement>("[data-gsap-session-body]")

        if (sessionSection && sessionShell && sessionBody) {
          gsap.fromTo(
            sessionShell,
            { autoAlpha: 0, y: 36, scale: 0.985 },
            {
              autoAlpha: 1,
              y: 0,
              scale: 1,
              duration: 0.9,
              ease: "power3.out",
              clearProps: "opacity,visibility,transform",
              scrollTrigger: {
                trigger: sessionSection,
                start: "top 72%",
                toggleActions: "play none none reverse",
              },
            },
          )

          const sessionLines = sessionBody.querySelectorAll(":scope > *")

          mm.add("(min-width: 1024px)", () => {
            const pinTimeline = gsap.timeline({
              scrollTrigger: {
                trigger: sessionShell,
                start: "top top+=96",
                end: "+=95%",
                scrub: 0.9,
                pin: true,
                anticipatePin: 1,
              },
            })

            pinTimeline
              .fromTo(
                ".terminal-preview-sheen",
                { opacity: 0.38 },
                { opacity: 0.74, ease: "none" },
                0,
              )
              .fromTo(
                ".terminal-preview-scanlines",
                { opacity: 0.32 },
                { opacity: 0.58, ease: "none" },
                0,
              )

            gsap.set(sessionLines, { autoAlpha: 1 })
          })

          mm.add("(max-width: 1023px)", () => {
            gsap.to(sessionShell, {
              yPercent: -4,
              rotateX: 1.4,
              transformOrigin: "center top",
              ease: "none",
              scrollTrigger: {
                trigger: sessionSection,
                start: "top bottom",
                end: "bottom top",
                scrub: 0.8,
              },
            })

            ScrollTrigger.batch(sessionLines, {
              start: "top 82%",
              once: true,
              interval: 0.08,
              batchMax: 6,
              onEnter: (batch) =>
                gsap.fromTo(
                  batch,
                  { autoAlpha: 0, x: -14 },
                  {
                    autoAlpha: 1,
                    x: 0,
                    duration: 0.45,
                    ease: "power2.out",
                    stagger: 0.05,
                    overwrite: true,
                    clearProps: "opacity,visibility,transform",
                  },
                ),
            })
          })
        }

        const workflowSection = root.querySelector<HTMLElement>('[data-gsap-scrolltrigger="workflow"]')
        const workflowHeader = root.querySelector<HTMLElement>("[data-gsap-workflow-header]")
        const workflowRows = gsap.utils.toArray<HTMLElement>("[data-gsap-workflow-row]", root)

        if (workflowSection && workflowHeader) {
          gsap.fromTo(
            workflowHeader,
            { autoAlpha: 0, y: 24 },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.8,
              ease: "power3.out",
              clearProps: "opacity,visibility,transform",
              scrollTrigger: {
                trigger: workflowSection,
                start: "top 72%",
                toggleActions: "play none none reverse",
              },
            },
          )
        }

        if (workflowRows.length > 0) {
          ScrollTrigger.batch(workflowRows, {
            start: "top 85%",
            once: true,
            interval: 0.1,
            batchMax: 4,
            onEnter: (batch) =>
              gsap.fromTo(
                batch,
                { autoAlpha: 0, y: 24, x: -10 },
                {
                  autoAlpha: 1,
                  y: 0,
                  x: 0,
                  duration: 0.62,
                  ease: "power3.out",
                  stagger: 0.08,
                  overwrite: true,
                  clearProps: "opacity,visibility,transform",
                },
              ),
          })
        }

        ScrollTrigger.refresh()
      }, root)

      homeMotionWindow.__bohrHomeMotionCleanup = () => {
        observer?.disconnect()
        mm.revert()
        ctx.revert()
      }
    }

    initHomepageMotion()

    if (!homeMotionWindow.__bohrHomeMotionBound) {
      document.addEventListener("astro:page-load", initHomepageMotion)
      document.addEventListener("astro:after-swap", initHomepageMotion)
      homeMotionWindow.__bohrHomeMotionBound = true
    }
  </script>

  <script is:inline>
    ;(function () {
      function initTerminalDemo() {
        if (window.__bohrTerminalCleanup) window.__bohrTerminalCleanup()
        window.__bohrTerminalCleanup = undefined

        var dataEl = document.getElementById("terminal-sample-data")
        var form = document.getElementById("terminal-command-form")
        var input = document.getElementById("terminal-command-input")
        var submit = document.getElementById("terminal-command-submit")
        var output = document.getElementById("terminal-output")
        var sessionBody = document.querySelector("[data-gsap-session-body]")
        var workspaceChip = document.querySelector("[data-terminal-workspace-chip]")
        var workspaceTitle = document.querySelector("[data-terminal-workspace-title]")
        var pidNode = document.querySelector("[data-terminal-pid]")
        var modelNode = document.querySelector("[data-terminal-model]")
        var toolsNode = document.querySelector("[data-terminal-tools]")
        var metaModelNode = document.querySelector("[data-terminal-meta-model]")
        var metaToolsNode = document.querySelector("[data-terminal-meta-tools]")
        var metaWorkspaceNode = document.querySelector("[data-terminal-meta-workspace]")
        var metaSessionNode = document.querySelector("[data-terminal-meta-session]")
        var commandNode = document.querySelector("[data-terminal-command-display]")
        var buttons = Array.from(document.querySelectorAll(".terminal-sample-trigger"))

        if (!dataEl || !form || !input || !submit || !output || !sessionBody || !commandNode) return

        var timers = []
        var samples = []

        try {
          samples = JSON.parse(dataEl.textContent || "[]")
        } catch (error) {
          return
        }

        if (!Array.isArray(samples) || samples.length === 0) return

        function clearTimers() {
          while (timers.length) {
            window.clearTimeout(timers.pop())
          }
        }

        function escapeHtml(value) {
          return String(value)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/\"/g, "&quot;")
            .replace(/'/g, "&#39;")
        }

        function sessionIdFor(sample) {
          return "preview-" + String(sample.id || "run").replace(/[^a-z0-9]+/gi, "-").replace(/^-+|-+$/g, "").toLowerCase()
        }

        function lineMarkup(line) {
          if (line.kind === "artifact") {
            return (
              '<p data-terminal-line class="text-neutral-700 transition-[opacity,transform] duration-300 dark:text-neutral-300">' +
              '<span class="text-neutral-500 dark:text-neutral-400">FILE</span> ' +
              '<span class="text-amber-900/90 dark:text-amber-200/90">' +
              escapeHtml(line.text) +
              "</span></p>"
            )
          }

          return (
            '<p data-terminal-line class="text-neutral-900 transition-[opacity,transform] duration-300 dark:text-neutral-200">' +
            '<span class="text-teal-700 dark:text-cyan-400">&gt; ' +
            escapeHtml(line.label || "RUN") +
            "</span> " +
            "<span>" +
            escapeHtml(line.text) +
            "</span></p>"
          )
        }

        function setText(node, value) {
          if (node) node.textContent = value
        }

        function setActiveButton(activeId) {
          buttons.forEach(function (button) {
            button.setAttribute("aria-pressed", button.getAttribute("data-terminal-sample-id") === activeId ? "true" : "false")
          })
        }

        function slugFromPrompt(prompt) {
          var topic = String(prompt).replace(/^\/\S+\s*/, "").toLowerCase()
          var slug = topic
            .split(/[^a-z0-9]+/)
            .filter(Boolean)
            .slice(0, 4)
            .join("-")
          return slug || "custom-run"
        }

        function createAdhocSample(prompt) {
          var cleanPrompt = prompt.trim() || "/deepresearch evaluate a custom topic"
          var command = cleanPrompt.split(/\s+/)[0] || "/deepresearch"
          var slug = slugFromPrompt(cleanPrompt)

          return {
            id: "custom",
            label: "Custom",
            workspace: "~/research/" + slug,
            pid: "18624",
            model: "CLAUDE-OPUS-4",
            tools: "25 TOOLS",
            prompt: cleanPrompt,
            lines: [
              { kind: "status", label: "QUEUE", text: "interactive replay staged from the prompt buffer" },
              { kind: "status", label: "PLAN", text: command + " expanded into a fresh execution graph" },
              { kind: "status", label: "FAN-OUT", text: "research, contradiction, and verification agents dispatched in parallel" },
              { kind: "status", label: "WRITE", text: "writer prepared a draft artifact and handed it to verification" },
              { kind: "artifact", text: "outputs/" + slug + ".md" },
              { kind: "artifact", text: "outputs/" + slug + ".provenance.md" },
            ],
          }
        }

        function findSample(prompt) {
          var normalized = String(prompt).toLowerCase()
          return (
            samples.find(function (sample) {
              if (normalized.indexOf(String(sample.id).toLowerCase()) !== -1) return true
              if (normalized.indexOf(String(sample.label).toLowerCase()) !== -1) return true
              return Array.isArray(sample.keywords)
                ? sample.keywords.some(function (keyword) {
                    return normalized.indexOf(String(keyword).toLowerCase()) !== -1
                  })
                : false
            }) || null
          )
        }

        function animateLines(lines) {
          output.innerHTML = ""
          lines.forEach(function (line, index) {
            var timer = window.setTimeout(function () {
              output.insertAdjacentHTML("beforeend", lineMarkup(line))
              var lastLine = output.lastElementChild
              if (lastLine) {
                lastLine.style.opacity = "0"
                lastLine.style.transform = "translateY(10px)"
                window.requestAnimationFrame(function () {
                  lastLine.style.opacity = "1"
                  lastLine.style.transform = "translateY(0)"
                })
              }
              sessionBody.scrollTop = sessionBody.scrollHeight
              if (index === lines.length - 1) submit.textContent = "Run sample"
            }, 90 * index)
            timers.push(timer)
          })
        }

        function renderSample(sample, source) {
          clearTimers()
          setText(workspaceChip, sample.workspace)
          setText(workspaceTitle, sample.workspace)
          setText(pidNode, sample.pid)
          setText(modelNode, sample.model)
          setText(toolsNode, sample.tools)
          setText(metaModelNode, sample.model)
          setText(metaToolsNode, sample.tools)
          setText(metaWorkspaceNode, sample.workspace)
          setText(metaSessionNode, sessionIdFor(sample))
          setText(commandNode, sample.prompt)
          input.value = sample.prompt
          sessionBody.scrollTop = 0
          submit.textContent = source === "initial" ? "Run sample" : "Running..."
          setActiveButton(sample.id === "custom" ? "" : sample.id)
          animateLines(sample.lines)
        }

        buttons.forEach(function (button) {
          if (button._bohrTerminalBound) return
          button._bohrTerminalBound = true
          button.addEventListener("click", function () {
            var sampleId = button.getAttribute("data-terminal-sample-id")
            var sample = samples.find(function (item) {
              return item.id === sampleId
            })
            if (!sample) return
            renderSample(sample, "button")
          })
        })

        if (!form._bohrTerminalBound) {
          form._bohrTerminalBound = true
          form.addEventListener("submit", function (event) {
            event.preventDefault()
            var prompt = input.value.trim()
            var matchedSample = findSample(prompt)
            if (matchedSample) {
              renderSample(
                {
                  id: matchedSample.id,
                  label: matchedSample.label,
                  workspace: matchedSample.workspace,
                  pid: matchedSample.pid,
                  model: matchedSample.model,
                  tools: matchedSample.tools,
                  prompt: prompt,
                  lines: matchedSample.lines,
                },
                "submit",
              )
              return
            }
            renderSample(createAdhocSample(prompt), "submit")
          })
        }

        renderSample(samples[0], "initial")
        window.__bohrTerminalCleanup = clearTimers
      }

      initTerminalDemo()

      if (!window.__bohrTerminalDemoBound) {
        document.addEventListener("astro:page-load", initTerminalDemo)
        document.addEventListener("astro:after-swap", initTerminalDemo)
        window.__bohrTerminalDemoBound = true
      }
    })()
  </script>

  <script is:inline>
    ;(function () {
      function init() {
        var toggles = Array.from(document.querySelectorAll(".install-toggle"))
        var btn = document.getElementById("install-copy-btn")
        var text = document.getElementById("install-command")
        var copyLabel = document.getElementById("install-copy-label")
        var feedback = document.getElementById("install-feedback")
        if (!btn || !text || !copyLabel || !feedback) return
        var feedbackTimeout

        function paintInstallTabs(activeToggle) {
          toggles.forEach(function (t) {
            var on = t === activeToggle
            t.setAttribute("aria-pressed", on ? "true" : "false")
          })
        }

        function setFeedback(message) {
          feedback.textContent = message
          if (feedbackTimeout) window.clearTimeout(feedbackTimeout)
          feedbackTimeout = window.setTimeout(function () {
            feedback.textContent = ""
          }, 2200)
        }

        function setCopyLabel(showSuccess) {
          copyLabel.textContent = showSuccess ? "COPIED" : "COPY"
        }

        function copyWithFallback(value) {
          if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
            return navigator.clipboard.writeText(value).then(function () {
              return true
            }).catch(function () {
              return false
            })
          }
          return Promise.resolve(false)
        }

        if (toggles.length) paintInstallTabs(toggles[0])

        toggles.forEach(function (toggle) {
          if (toggle._bohrInstallBound) return
          toggle._bohrInstallBound = true
          toggle.addEventListener("click", function () {
            var cmd = toggle.getAttribute("data-command")
            if (!cmd) return
            btn.setAttribute("data-command", cmd)
            text.textContent = cmd
            paintInstallTabs(toggle)
            setCopyLabel(false)
            setFeedback("")
          })
        })

        if (!btn._bohrInstallBound) {
          btn._bohrInstallBound = true
          btn.addEventListener("click", function () {
            var cmd = btn.getAttribute("data-command")
            if (!cmd) return
            copyWithFallback(cmd).then(function (copied) {
              if (copied) {
                setCopyLabel(true)
                setFeedback("Copied to clipboard.")
                window.setTimeout(function () {
                  setCopyLabel(false)
                }, 2000)
                return
              }
              setCopyLabel(false)
              setFeedback("Copy failed - select the command and copy manually.")
            })
          })
        }
      }
      init()
      document.addEventListener("astro:after-swap", init)
    })()
  </script>
</Layout>
