---
import Layout from "@/layouts/main.astro"
import { BOHR_SEMVER } from "@/data/bohr-root-version"

const docsCommands = "/docs/reference/slash-commands"

const slashCommands = [
  {
    cmd: "/audit",
    desc: "Compare a paper's claims against its codebase for reproducibility.",
  },
  {
    cmd: "/autoresearch",
    desc: "Automated experiment loop: analyze, measure, hypothesize, test.",
  },
  {
    cmd: "/compare",
    desc: "Agreement / disagreement matrix across sources on a topic.",
  },
  {
    cmd: "/deepresearch",
    desc: "Durable research brief with inline citations and provenance.",
  },
  {
    cmd: "/draft",
    desc: "Turn findings into a structured, multi-step manuscript draft.",
  },
  {
    cmd: "/lit",
    desc: "Literature review with search, synthesis, and gap mapping.",
  },
  {
    cmd: "/replicate",
    desc: "Replication plan or workflow for a paper, claim, or benchmark.",
  },
  {
    cmd: "/review",
    desc: "Simulated peer review with severity and revision guidance.",
  },
  {
    cmd: "/watch",
    desc: "Recurring monitoring on a topic or literature area.",
  },
  {
    cmd: "/plan-research",
    desc: "Orchestration plan: agents, checkpoints, and stop criteria.",
  },
] as const

const installCommands = [
  { label: "curl", command: "curl -fsSL https://bohr-ai.internal/install | bash" },
] as const

const demoQuery =
  "What are the most effective optimization techniques for transformer architectures?"

const demoPapers = [
  {
    title: "Adafactor",
    year: "2019",
    note: "Adaptive learning rates with factorized second-moment estimates; popular for memory-efficient large-model training.",
  },
  {
    title: "Attention Is All You Need",
    year: "2017",
    note: "Foundational transformer architecture; baseline for most efficiency work on sequence models.",
  },
  {
    title: "LongNet",
    year: "2023",
    note: "Dilated attention scaling toward very long contexts; representative of recent linear-attention trends.",
  },
] as const
---

<Layout
  title="Bohr — CLI research shell"
  description="Run slash-command research workflows in a terminal-native Pi agent: literature, synthesis, validation."
  active="home"
  shell="cli"
>
  <div class="cli-home-root page-gutter-x w-full min-w-0 flex-1 pb-12 pt-2 sm:pb-16 sm:pt-4">
    <div
      class="w-full max-w-none border border-[#333333] bg-[#0a0a0a] shadow-[0_0_0_1px_rgba(255,255,255,0.03)]"
    >
      <!-- Title bar -->
      <div
        class="flex items-center justify-center border-b border-[#262626] px-3 py-2.5 text-center text-[10px] uppercase tracking-[0.18em] text-[#737373] sm:px-4 sm:text-[11px]"
      >
        bohr — local session
      </div>

      <!-- Brand -->
      <div class="border-b border-[#262626] px-4 py-8 text-center sm:px-8 sm:py-12 md:px-12 md:py-14">
        <p class="font-['VT323'] text-[clamp(2.75rem,10vw+1rem,8rem)] leading-none tracking-tight text-[#fafafa]">
          bohr
        </p>
        <p class="mt-3 font-[family-name:var(--font-cli)] text-sm text-[#737373]">v{BOHR_SEMVER}</p>
      </div>

      <!-- Status + commands -->
      <div class="grid gap-0 border-b border-[#262626] md:grid-cols-2">
        <section
          class="border-b border-[#262626] p-4 font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-[#d4d4d4] sm:p-5 sm:text-[13px] md:border-b-0 md:border-r lg:p-6 xl:p-8"
          aria-label="Session status"
        >
          <p class="mb-3 text-[11px] uppercase tracking-[0.16em] text-[#737373]">System status</p>
          <dl class="space-y-2.5">
            <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
              <dt class="shrink-0 text-[#737373]">model</dt>
              <dd class="min-w-0 break-all text-[#e5e5e5]">anthropic/claude-opus-4-20250514</dd>
            </div>
            <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
              <dt class="shrink-0 text-[#737373]">session</dt>
              <dd class="min-w-0 break-all font-mono text-[12px] text-[#a3a3a3]">
                a8f3c21e-4b90-7d14 · active
              </dd>
            </div>
            <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
              <dt class="shrink-0 text-[#737373]">host</dt>
              <dd class="text-[#a3a3a3]">your machine · docker optional</dd>
            </div>
            <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
              <dt class="shrink-0 text-[#737373]">inventory</dt>
              <dd class="text-[#a3a3a3]">25+ tools · default agents</dd>
            </div>
            <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
              <dt class="shrink-0 text-[#737373]">agents</dt>
              <dd class="text-[#e5e5e5]">researcher, reviewer, verifier, writer, …</dd>
            </div>
            <div class="flex flex-col gap-1 border-t border-[#1f1f1f] pt-3">
              <dt class="text-[#737373]">last activity</dt>
              <dd class="text-[12px] text-[#a3a3a3]">
                bohr[1 query] &quot;data efficiency transformer architecture optimiz…&quot;
              </dd>
            </div>
          </dl>
          <p class="mt-6 border border-[#333333] bg-[#050505] px-3 py-2 text-[12px] text-[#d4d4d4]">
            <span class="select-none text-[#737373]">&gt;</span>
            <span class="text-[#fafafa]">{demoQuery}</span>
          </p>
        </section>

        <section
          class="p-4 font-[family-name:var(--font-cli)] text-[12px] leading-relaxed sm:p-5 sm:text-[13px] lg:p-6 xl:p-8"
          aria-label="Slash commands"
        >
          <p class="mb-3 text-[11px] uppercase tracking-[0.16em] text-[#737373]">Research workflows</p>
          <p class="mb-4 text-[12px] text-[#737373]">
            Type in the Bohr REPL. Full list in
            <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href={docsCommands}
              >slash commands</a
            >.
          </p>
          <ul
            class="max-h-[min(48vh,24rem)] space-y-3 overflow-y-auto overscroll-contain pr-1 text-[#d4d4d4] sm:max-h-[min(52vh,26rem)] md:max-h-[min(58vh,28rem)] lg:max-h-[min(68vh,34rem)] xl:max-h-[min(75vh,40rem)] 2xl:max-h-[min(78vh,44rem)]"
          >
            {slashCommands.map((item) => (
              <li class="border-l border-[#333333] pl-3">
                <a
                  href={docsCommands}
                  class="font-mono text-[#fafafa] hover:text-white focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[#737373]"
                >
                  {item.cmd}
                </a>
                <span class="text-[#737373]"> — </span>
                <span class="text-[#a3a3a3]">{item.desc}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <!-- Output + hero -->
      <div class="grid grid-cols-1 gap-0 md:grid-cols-2 xl:grid-cols-12 xl:items-stretch">
        <div
          class="border-b border-[#262626] p-4 font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-[#d4d4d4] sm:p-5 sm:text-[13px] md:border-b-0 md:border-r xl:col-span-7 xl:border-b-0 lg:p-6 xl:p-8"
        >
          <p class="mb-3 flex flex-wrap items-baseline gap-2 text-[11px] uppercase tracking-[0.16em] text-[#737373]">
            <span class="inline-block translate-y-px font-sans text-[#a3a3a3]" aria-hidden="true">↗</span>
            output stream
          </p>
          <p class="mb-2 flex flex-wrap items-baseline gap-2 text-[#e5e5e5]">
            <span class="font-sans text-[#737373]" aria-hidden="true">↗</span>
            <span>{demoQuery}</span>
          </p>
          <p class="mb-6 text-[12px] text-[#a3a3a3]">
            Below is an illustrative excerpt: ranked papers and one-line cues—your live run streams tool calls,
            citations, and file paths in the REPL.
          </p>
          <p class="mb-3 flex items-center gap-2 text-[12px] text-[#737373]">
            <span aria-hidden="true">↗</span> search · top papers
          </p>
          <ol class="list-decimal space-y-4 pl-5 marker:text-[#525252]">
            {demoPapers.map((p, i) => (
              <li class="pl-1">
                <span class="text-[#fafafa]">
                  {i + 1}. {p.title}
                </span>
                <span class="text-[#737373]"> ({p.year})</span>
                <span class="mt-1 block text-[12px] leading-snug text-[#a3a3a3]">{p.note}</span>
              </li>
            ))}
          </ol>
        </div>
        <div
          class="flex flex-col justify-center border-[#262626] bg-[#050505] p-3 sm:p-4 md:border-l xl:col-span-5 xl:border-l xl:border-t-0"
        >
          <figure class="mx-auto w-full max-w-full">
            <img
              src="/hero.png"
              width={960}
              height={540}
              alt="Bohr CLI session preview"
              class="mx-auto h-auto max-h-[min(42vh,280px)] w-full border border-[#262626] object-contain sm:max-h-[min(48vh,360px)] md:max-h-[55vh] lg:max-h-none lg:max-w-full"
              loading="eager"
              decoding="async"
            />
            <figcaption class="mt-3 text-center text-[11px] text-[#737373]">
              Same tool in your terminal — this page is a static preview.
            </figcaption>
          </figure>
        </div>
      </div>

      <!-- Install -->
      <div class="border-t border-[#262626] p-4 sm:p-6 lg:p-8">
        <p class="mb-3 text-[11px] uppercase tracking-[0.16em] text-[#737373]">Install</p>
        <div class="font-[family-name:var(--font-cli)] text-[13px]">
          <div class="flex max-w-full flex-col overflow-hidden rounded-sm border border-[#333333] bg-[#050505]">
            <div class="flex overflow-x-auto border-b border-[#262626]" role="group" aria-label="Install command format">
              {installCommands.map((entry, i) => (
                <button
                  type="button"
                  class:list={[
                    "install-toggle cli-install-tab shrink-0 px-4 py-2.5 text-left text-[12px] transition-colors cursor-pointer",
                  ]}
                  data-command={entry.command}
                  aria-pressed={i === 0 ? "true" : "false"}
                >
                  {entry.label}
                </button>
              ))}
            </div>
            <button
              id="install-cmd"
              type="button"
              class="group flex w-full min-w-0 items-start justify-between gap-3 px-4 py-3 text-left text-[12px] text-[#d4d4d4] transition-colors hover:bg-[#111111] sm:items-center"
              data-command={installCommands[0].command}
              aria-label="Copy install command"
            >
              <span id="install-command" class="min-w-0 flex-1 break-all leading-relaxed">
                {installCommands[0].command}
              </span>
              <svg
                id="install-copy"
                class="mt-0.5 size-4 shrink-0 text-[#737373] group-hover:text-[#fafafa] sm:mt-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <rect x="9" y="9" width="13" height="13" rx="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
              <svg
                id="install-check"
                class="mt-0.5 hidden size-4 shrink-0 text-[#a3a3a3] sm:mt-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M20 6L9 17l-5-5" />
              </svg>
            </button>
          </div>
          <p id="install-feedback" class="mt-2 min-h-[1.25rem] text-[12px] text-[#737373]" aria-live="polite" />
          <p class="mt-4 text-[12px] text-[#737373]">
            Prefer a guided setup?
            <a
              class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]"
              href="/docs/getting-started/installation">Installation docs</a
            >.
          </p>
        </div>
      </div>
    </div>

    <nav
      class="mt-8 w-full max-w-none border border-[#333333] bg-[#0a0a0a] px-4 py-4 font-[family-name:var(--font-cli)] text-[12px] sm:mt-10 sm:px-6 sm:text-[13px] lg:px-8"
      aria-label="Learn Bohr"
    >
      <p class="mb-3 text-[11px] uppercase tracking-[0.16em] text-[#737373]">Learn the product</p>
      <ul class="flex flex-col gap-3 text-[#d4d4d4] sm:flex-row sm:flex-wrap sm:gap-x-6 sm:gap-y-2 md:gap-x-8">
        <li>
          <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href="/explore">Explore</a>
          <span class="text-[#525252]"> — </span>
          <span class="text-[#a3a3a3]">map of docs & hubs</span>
        </li>
        <li>
          <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href="/agents">Agents</a>
          <span class="text-[#525252]"> — </span>
          <span class="text-[#a3a3a3]">who does what</span>
        </li>
        <li>
          <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href="/workflows">Workflows</a>
          <span class="text-[#525252]"> — </span>
          <span class="text-[#a3a3a3]">slash-command outcomes</span>
        </li>
        <li>
          <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href="/how-it-works">Process</a>
          <span class="text-[#525252]"> — </span>
          <span class="text-[#a3a3a3]">steps & diagrams</span>
        </li>
        <li>
          <a class="text-[#fafafa] underline decoration-[#525252] underline-offset-2 hover:decoration-[#a3a3a3]" href="/docs">Docs</a>
          <span class="text-[#525252]"> — </span>
          <span class="text-[#a3a3a3]">full guides</span>
        </li>
      </ul>
    </nav>
  </div>

  <script is:inline>
    ;(function () {
      function init() {
        var toggles = Array.from(document.querySelectorAll(".install-toggle"))
        var btn = document.getElementById("install-cmd")
        var text = document.getElementById("install-command")
        var copyIcon = document.getElementById("install-copy")
        var checkIcon = document.getElementById("install-check")
        var feedback = document.getElementById("install-feedback")
        if (!btn || !text || !copyIcon || !checkIcon || !feedback) return
        var feedbackTimeout

        function setFeedback(message) {
          feedback.textContent = message
          if (feedbackTimeout) window.clearTimeout(feedbackTimeout)
          feedbackTimeout = window.setTimeout(function () {
            feedback.textContent = ""
          }, 2200)
        }

        function setCopyIcons(showSuccess) {
          if (showSuccess) {
            copyIcon.classList.add("hidden")
            checkIcon.classList.remove("hidden")
          } else {
            copyIcon.classList.remove("hidden")
            checkIcon.classList.add("hidden")
          }
        }

        function copyWithFallback(value) {
          if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
            return navigator.clipboard.writeText(value).then(function () {
              return true
            }).catch(function () {
              return false
            })
          }
          return Promise.resolve(false)
        }

            toggles.forEach(function (toggle) {
              if (toggle._bohrInstallBound) return
              toggle._bohrInstallBound = true
              toggle.addEventListener("click", function () {
                var cmd = toggle.getAttribute("data-command")
                if (!cmd) return
                btn.setAttribute("data-command", cmd)
                text.textContent = cmd
                toggles.forEach(function (t) {
                  t.setAttribute("aria-pressed", "false")
                })
                toggle.setAttribute("aria-pressed", "true")
                setCopyIcons(false)
                setFeedback("Selected " + (toggle.textContent || "").trim())
              })
            })

        if (!btn._bohrInstallBound) {
          btn._bohrInstallBound = true
          btn.addEventListener("click", function () {
            var cmd = btn.getAttribute("data-command")
            if (!cmd) return
            copyWithFallback(cmd).then(function (copied) {
              if (copied) {
                setCopyIcons(true)
                setFeedback("Copied to clipboard.")
                setTimeout(function () {
                  setCopyIcons(false)
                }, 2000)
                return
              }
              setCopyIcons(false)
              setFeedback("Copy failed — select the command and copy manually.")
            })
          })
        }
      }
      init()
      document.addEventListener("astro:after-swap", init)
    })()
  </script>
</Layout>
