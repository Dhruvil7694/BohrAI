---
import Layout from "@/layouts/main.astro"
import { BOHR_SEMVER } from "@/data/bohr-root-version"
import { BOHR_GITHUB_REPO_URL, BOHR_INSTALL_SH_URL } from "@/data/site-urls"

const installCommands = [
  { label: "curl", command: `curl -fsSL ${BOHR_INSTALL_SH_URL} | bash` },
  { label: "brew", command: "brew tap bohr-ai/tap && brew install bohr" },
  { label: "pipx", command: "pipx install bohr-ai" },
] as const

const pillars = [
  {
    roman: "I.",
    title: "Multi-agent, by design",
    body:
      "Researcher, reviewer, verifier, writer, contradiction - 20+ specialised subagents coordinated by an orchestrator.",
  },
  {
    roman: "II.",
    title: "Cited & verified",
    body:
      "Every claim is anchored to a source; a verifier agent cross-checks citations against their text before delivery.",
  },
  {
    roman: "III.",
    title: "CLI-first",
    body:
      "Nothing depends on a proprietary dashboard. Artifacts land as markdown in your repo, versionable with git.",
  },
  {
    roman: "IV.",
    title: "Adversarial loop",
    body:
      "Findings are stress-tested by a contradiction agent and a reasoning validator until convergence criteria are met.",
  },
] as const

/** Homepage workflow strip - maps to `/workflows/[slug]` pages. */
const workflowsShowcase = [
  {
    cmd: "/deepresearch",
    index: "01",
    slug: "deep-research",
    desc: "Durable research brief with inline citations, provenance, and verification.",
  },
  {
    cmd: "/lit-review",
    index: "02",
    slug: "lit-review",
    desc: "End-to-end literature survey with themes, contradictions, gaps and validation.",
  },
  {
    cmd: "/paper",
    index: "03",
    slug: "paper",
    desc: "Publication-grade manuscript with method, figures, citation & compliance passes.",
  },
  {
    cmd: "/visuals",
    index: "04",
    slug: "visuals",
    desc: "Data-backed charts, source-linked tables, and conceptual image assets.",
  },
  {
    cmd: "/review",
    index: "05",
    slug: "review",
    desc: "Simulated peer review with severity-graded feedback and revision guidance.",
  },
  {
    cmd: "/audit",
    index: "06",
    slug: "audit",
    desc: "Compare a paper's claims against its public codebase for reproducibility.",
  },
  {
    cmd: "/replicate",
    index: "07",
    slug: "replication",
    desc: "Replication plan or workflow for a paper, claim, or benchmark.",
  },
  {
    cmd: "/compare",
    index: "08",
    slug: "compare",
    desc: "Agreement / disagreement matrix across sources on a topic.",
  },
  {
    cmd: "/autoresearch",
    index: "09",
    slug: "autoresearch",
    desc: "Autonomous experiment loop that iteratively optimizes toward a stated goal.",
  },
  {
    cmd: "/draft",
    index: "10",
    slug: "draft",
    desc: "Turn findings into a structured, multi-step manuscript draft.",
  },
  {
    cmd: "/watch",
    index: "11",
    slug: "watch",
    desc: "Recurring monitoring on a topic or literature area.",
  },
] as const

const terminalSamples = [
  {
    id: "transformers",
    label: "Transformers",
    workspace: "~/research/transformers",
    pid: "18332",
    model: "CLAUDE-OPUS-4",
    tools: "25 TOOLS",
    prompt: "/deepresearch optimization techniques for transformer architectures",
    keywords: ["transformer", "attention", "optimization", "architecture"],
    lines: [
      { kind: "status", label: "PLAN", text: "research-planner scoped 7 stages | 4 researchers | stop@conf>0.85" },
      { kind: "status", label: "FAN-OUT", text: "AlphaXiv, web, and code search dispatched in parallel" },
      { kind: "status", label: "CHECK", text: "contradiction agent found 2 efficiency tradeoff disputes" },
      { kind: "status", label: "VERIFY", text: "verifier anchored 87/87 citations before final promotion" },
      { kind: "artifact", text: "outputs/transformer-optimization.md | 4,281 words | 87 citations" },
      { kind: "artifact", text: "outputs/transformer-optimization.provenance.md" },
    ],
  },
  {
    id: "lit-review",
    label: "Literature review",
    workspace: "~/research/scaling-laws",
    pid: "18407",
    model: "CLAUDE-OPUS-4",
    tools: "25 TOOLS",
    prompt: "/lit-review post-chinchilla scaling laws and inference-time compute",
    keywords: ["literature", "lit-review", "scaling", "chinchilla", "inference"],
    lines: [
      { kind: "status", label: "COLLECT", text: "collector gathered 42 candidate papers across 2022-2026" },
      { kind: "status", label: "SYNTH", text: "synthesizer grouped findings into training, data, and test-time axes" },
      { kind: "status", label: "GAP", text: "gap pass flagged sparse public evidence for inference-time scaling laws" },
      { kind: "status", label: "REVIEW", text: "reviewer requested tighter wording around heterogeneous benchmarks" },
      { kind: "artifact", text: "outputs/scaling-laws.md | qualitative meta-analysis" },
      { kind: "artifact", text: "notes/scaling-laws-verification.md" },
    ],
  },
  {
    id: "audit",
    label: "Code audit",
    workspace: "~/research/repro-audit",
    pid: "18591",
    model: "CLAUDE-OPUS-4",
    tools: "25 TOOLS",
    prompt: "/audit does the released repo support the paper's reproducibility claims?",
    keywords: ["audit", "reproducibility", "repo", "codebase", "claims"],
    lines: [
      { kind: "status", label: "MAP", text: "repo mapper aligned paper claims to scripts, configs, and checkpoints" },
      { kind: "status", label: "EXEC", text: "experiment pass verified 3/5 benchmark scripts are runnable as documented" },
      { kind: "status", label: "RISK", text: "missing seed control and hidden preprocessing steps marked as MAJOR" },
      { kind: "status", label: "WRITE", text: "audit brief drafted with severity-graded evidence table" },
      { kind: "artifact", text: "outputs/repro-audit.md | claim/code agreement matrix" },
      { kind: "artifact", text: "outputs/repro-audit.provenance.md" },
    ],
  },
  {
    id: "visuals",
    label: "Visuals",
    workspace: "~/research/market-visuals",
    pid: "18612",
    model: "GPT-5.4",
    tools: "28 TOOLS",
    prompt: "/visuals AI agent market comparison charts and material board",
    keywords: ["visuals", "chart", "table", "image", "market", "comparison"],
    lines: [
      { kind: "status", label: "PLAN", text: "visual package scoped: source data, chart, comparison table, concept image" },
      { kind: "status", label: "DATA", text: "market rows normalized to data.json and data.csv before rendering" },
      { kind: "status", label: "CHART", text: "data-backed SVG chart generated from structured rows" },
      { kind: "status", label: "IMAGE", text: "concept visual routed to configured Nano Banana / OpenAI provider" },
      { kind: "artifact", text: "outputs/ai-agent-market.assets/manifest.json" },
      { kind: "artifact", text: "outputs/ai-agent-market.md | provenance included" },
    ],
  },
] as const

const defaultTerminalSample = terminalSamples[0]
---

<Layout
  title="Bohr - CLI research shell"
  description="Run slash-command research workflows in a terminal-native Pi agent: literature, synthesis, validation."
  active="home"
  shell="cli"
>
  <div
    class="cli-home-root page-gutter-x mx-auto flex w-full max-w-5xl min-w-0 flex-1 flex-col gap-4 pb-12 pt-2 sm:gap-5 sm:pb-16 sm:pt-4"
  >
      <!-- Hero - editorial / laboratory masthead -->
      <section
        data-gsap-hero
        class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] flex min-h-[calc(100svh-5.25rem)] w-screen flex-col bg-[var(--bohr-shell-bg)] text-center"
        aria-label="Bohr hero"
      >
        <div
          data-gsap-hero-shell
          class="relative flex w-full max-w-none flex-1 flex-col px-4 pb-10 pt-10 sm:px-5 sm:pb-14 sm:pt-12 md:px-6 md:pb-16 lg:px-8 xl:px-10"
        >
          <div
            data-gsap-hero-top
            class="mb-10 grid grid-cols-1 gap-3 text-[10px] uppercase tracking-[0.24em] sm:mb-14 sm:grid-cols-3 sm:items-center sm:gap-6 sm:text-[11px]"
          >
            <span class="font-[family-name:var(--font-cli)] text-[var(--bohr-shell-fg)] sm:text-left">00 | INDEX</span>
            <span class="font-[family-name:var(--font-cli)] text-neutral-600 sm:text-center dark:text-[#a3a3a3]"
              >- BOHR RESEARCH LABORATORY | LOCAL SESSION -</span
            >
            <span class="font-[family-name:var(--font-cli)] text-[var(--bohr-shell-fg)] sm:text-right">PUBLISHED MMXXVI</span>
          </div>

          <h1 data-gsap-hero-title class="flex flex-wrap items-baseline justify-center gap-2 sm:gap-3 md:gap-4">
            <span
              class="font-['Inter',system-ui,sans-serif] text-[clamp(6rem,min(46vw,38vh),20rem)] font-bold leading-[0.86] tracking-[-0.045em] text-[var(--bohr-shell-fg)]"
            >
              Bohr
            </span>
            <span
              class="font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(5.75rem,min(43vw,36vh),19rem)] font-normal italic leading-[0.86] text-[var(--bohr-shell-accent-serif)]"
            >
              AI
            </span>
          </h1>

          <p
            data-gsap-hero-meta
            class="mt-4 font-[family-name:var(--font-cli)] text-[11px] tracking-[0.08em] text-neutral-600 sm:text-xs dark:text-[#737373]"
          >
            v{BOHR_SEMVER}
          </p>

          <div data-gsap-hero-rule class="mt-12 flex w-full items-center gap-4 sm:mt-14">
            <span class="h-px min-h-px flex-1 bg-neutral-900/20 dark:bg-[#333333]" aria-hidden="true" />
            <span class="shrink-0 font-[family-name:var(--font-cli)] text-[10px] uppercase tracking-[0.26em] text-neutral-600 sm:text-[11px] dark:text-[#a3a3a3]">
              VOL. II | NO. 17 - CLI RESEARCH SHELL
            </span>
            <span class="h-px min-h-px flex-1 bg-neutral-900/20 dark:bg-[#333333]" aria-hidden="true" />
          </div>

          <p
            data-gsap-hero-copy
            class="mx-auto mt-12 max-w-[min(42rem,calc(100vw-2.5rem))] font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(1.45rem,4.8vw,2rem)] font-normal italic leading-[1.55] text-[var(--bohr-shell-fg)] sm:mt-14 md:leading-[1.6]"
          >
            A multi-agent research shell that assembles, critiques and verifies a paper the way a lab does - from literature
            sweep to peer review, in your terminal.
          </p>

          <div data-gsap-hero-ctas class="mt-12 flex flex-col items-center justify-center gap-4 sm:mt-14 sm:flex-row sm:gap-5">
            <a
              data-gsap-cta
              class="inline-flex min-w-[13rem] items-center justify-center rounded-[2px] bg-[var(--bohr-shell-fg)] px-8 py-3.5 font-[family-name:var(--font-cli)] text-[12px] font-medium uppercase tracking-[0.18em] text-[var(--bohr-shell-bg)] transition-colors hover:bg-neutral-800 hover:text-[var(--bohr-shell-bg)] dark:bg-[#fafafa] dark:text-black dark:hover:bg-[#e5e5e5]"
              href="/docs/getting-started/installation"
            >
              Install Bohr ->
            </a>
            <a
              data-gsap-cta
              class="inline-flex min-w-[13rem] items-center justify-center rounded-[2px] border border-[var(--bohr-shell-fg)] bg-transparent px-8 py-3.5 font-[family-name:var(--font-cli)] text-[12px] uppercase tracking-[0.18em] text-[var(--bohr-shell-fg)] transition-colors hover:bg-black/5 dark:border-[#fafafa] dark:text-[var(--bohr-shell-fg)] dark:hover:bg-[#fafafa]/10"
              href="#session-preview"
            >
              See a session
            </a>
          </div>
        </div>
      </section>

      <!-- Live terminal UI (static replay) -->
      <section
        id="session-preview"
        data-gsap-reveal
        data-gsap-scrolltrigger="session"
        class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] -mt-4 w-screen scroll-mt-24 bg-[var(--bohr-shell-bg)] pb-12 pt-10 sm:-mt-5 sm:pb-16 sm:pt-12"
        aria-labelledby="live-terminal-heading"
      >
        <div class="relative flex w-full max-w-none flex-col gap-8 px-4 sm:gap-10 sm:px-5 md:px-6 lg:px-8 xl:px-10">
          <div
            data-gsap-stagger-item
            class="flex flex-col gap-3 text-[10px] uppercase tracking-[0.22em] text-neutral-500 sm:flex-row sm:items-center sm:justify-between sm:text-[11px]"
          >
            <span class="font-[family-name:var(--font-cli)] text-neutral-500">-- FIG. 01 | LIVE SESSION</span>
            <span class="font-[family-name:var(--font-cli)] text-neutral-500 sm:text-right">/DEEPRESEARCH - <span data-terminal-workspace-chip>{defaultTerminalSample.workspace}</span></span>
          </div>

          <h2
            id="live-terminal-heading"
            data-gsap-stagger-item
            class="font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(1.75rem,5vw,2.75rem)] font-normal leading-tight tracking-tight text-[var(--bohr-shell-fg)]"
          >
            A real run, replayed.
          </h2>

          <div
            data-gsap-stagger-item
            class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <p class="font-[family-name:var(--font-cli)] text-[10px] uppercase tracking-[0.18em] text-neutral-500 sm:text-[11px]">
              Click a sample or type your own workflow prompt
            </p>
            <div class="flex flex-wrap gap-2" role="group" aria-label="Terminal samples">
              {terminalSamples.map((sample, index) => (
                <button
                  type="button"
                  class="terminal-sample-trigger rounded-[2px] border border-[color:var(--bohr-shell-border)] bg-transparent px-3 py-1.5 font-[family-name:var(--font-cli)] text-[10px] uppercase tracking-[0.12em] text-neutral-600 transition-colors hover:text-[var(--bohr-shell-fg)] aria-pressed:border-[var(--bohr-shell-fg)] aria-pressed:bg-[var(--bohr-shell-fg)] aria-pressed:text-[var(--bohr-shell-bg)] dark:text-neutral-400 dark:hover:text-neutral-100 dark:aria-pressed:border-neutral-100 dark:aria-pressed:bg-neutral-100 dark:aria-pressed:text-black"
                  data-terminal-sample-id={sample.id}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {sample.label}
                </button>
              ))}
            </div>
          </div>

          <div
            data-gsap-stagger-item
            data-gsap-session-shell
            class="group terminal-preview-shell min-h-[30rem] overflow-hidden rounded-lg border border-[color:var(--bohr-shell-border)] bg-[color-mix(in_oklab,var(--bohr-shell-fg)_5%,var(--bohr-shell-bg))] shadow-[0_1px_0_rgba(255,255,255,0.75)_inset,0_18px_48px_-20px_rgba(15,75,65,0.09)] ring-1 ring-black/[0.06] sm:min-h-[34rem] lg:min-h-[38rem] dark:border-white/10 dark:bg-neutral-950 dark:shadow-[0_0_0_1px_rgba(255,255,255,0.04)_inset,0_24px_80px_-24px_rgba(34,211,238,0.06)] dark:ring-transparent"
          >
            <div class="terminal-preview-sheen" aria-hidden="true" />
            <div class="terminal-preview-scanlines" aria-hidden="true" />

            <div class="relative z-[3] flex h-full min-h-0 [min-height:inherit] flex-col">
              <!-- Title bar -->
              <div
                class="flex min-h-[2.5rem] flex-wrap items-center gap-2 border-b border-black/10 bg-[color-mix(in_oklab,var(--bohr-shell-fg)_7%,var(--bohr-shell-bg))] px-3 py-2 font-[family-name:var(--font-cli)] text-[10px] text-neutral-600 sm:flex-nowrap sm:px-4 sm:text-[11px] dark:border-white/10 dark:bg-[#0a0a0a] dark:text-neutral-400"
              >
                <div class="flex shrink-0 items-center gap-1.5" aria-hidden="true">
                  <span class="size-2.5 rounded-full bg-[#ff5f57] shadow-[0_0_6px_rgba(255,95,87,0.45)]"></span>
                  <span class="size-2.5 rounded-full bg-[#febc2e] shadow-[0_0_6px_rgba(254,188,46,0.35)]"></span>
                  <span class="size-2.5 rounded-full bg-[#28c840] shadow-[0_0_6px_rgba(40,200,64,0.35)]"></span>
                </div>
                <p class="min-w-0 flex-1 text-center text-neutral-800 sm:px-2 dark:text-neutral-300">
                  BOHR <span data-terminal-workspace-title>{defaultTerminalSample.workspace}</span>
                </p>
                <div class="flex w-full flex-wrap items-center justify-end gap-x-3 gap-y-1.5 sm:w-auto sm:shrink-0">
                  <span class="inline-flex items-center gap-1.5 rounded-[2px] border border-emerald-700/25 bg-emerald-600/[0.08] px-2 py-0.5 dark:border-emerald-500/30 dark:bg-emerald-500/[0.07]">
                    <span
                      class="terminal-live-led size-1.5 shrink-0 rounded-full bg-emerald-600 dark:bg-emerald-400"
                      aria-hidden="true"
                    />
                    <span class="text-[9px] font-medium uppercase tracking-[0.16em] text-emerald-800 dark:text-emerald-400/95">Live</span>
                  </span>
                  <p class="text-neutral-600 dark:text-neutral-500">
                    PID <span data-terminal-pid>{defaultTerminalSample.pid}</span> - <span data-terminal-model>{defaultTerminalSample.model}</span> - <span data-terminal-tools>{defaultTerminalSample.tools}</span>
                  </p>
                </div>
              </div>

              <!-- Terminal body -->
              <div
                data-gsap-session-body
                class="min-h-0 flex-1 overflow-visible bg-[color-mix(in_oklab,var(--bohr-shell-fg)_4%,var(--bohr-shell-bg))] px-3 py-4 font-[family-name:var(--font-cli)] text-[11px] leading-[1.65] text-neutral-800 sm:px-5 sm:text-[12px] sm:leading-relaxed dark:bg-[#060606]/80 dark:text-neutral-200"
              >
                <div class="space-y-1 text-neutral-600 dark:text-neutral-500">
                  <p>
                    # bohr v{BOHR_SEMVER} - <span data-terminal-meta-model>{defaultTerminalSample.model}</span> -
                    <span data-terminal-meta-tools>{defaultTerminalSample.tools}</span> - host: local machine
                  </p>
                  <p>
                    # workspace: <span data-terminal-meta-workspace>{defaultTerminalSample.workspace}</span> - session:
                    <span data-terminal-meta-session>preview-transformers</span>
                  </p>
                </div>

                <p class="mt-5 text-neutral-900 dark:text-neutral-200">
                  <span class="text-neutral-600 dark:text-neutral-400">bohr&gt;</span>{" "}
                  <span data-terminal-command-display class="text-neutral-950 dark:text-neutral-100">{defaultTerminalSample.prompt}</span>
                </p>

                <div class="my-5 border-t border-black/10 dark:border-white/10" aria-hidden="true" />

                <div id="terminal-output" aria-live="polite" class="space-y-2.5">
                  {defaultTerminalSample.lines.map((line) => (
                    <p data-terminal-line class={line.kind === "artifact" ? "text-neutral-700 dark:text-neutral-300" : "text-neutral-900 dark:text-neutral-200"}>
                      {line.kind === "status" ? (
                        <>
                          <span class="text-teal-700 dark:text-cyan-400">&gt; {line.label}</span>{" "}
                          <span>{line.text}</span>
                        </>
                      ) : (
                        <>
                          <span class="text-neutral-500 dark:text-neutral-400">FILE</span>{" "}
                          <span class="text-amber-900/90 dark:text-amber-200/90">{line.text}</span>
                        </>
                      )}
                    </p>
                  ))}
                </div>
              </div>

              <form
                id="terminal-command-form"
                class="flex flex-col gap-3 border-t border-black/10 bg-[color-mix(in_oklab,var(--bohr-shell-fg)_6%,var(--bohr-shell-bg))] px-3 py-3 font-[family-name:var(--font-cli)] text-[11px] sm:flex-row sm:items-center sm:px-5 sm:text-[12px] dark:border-white/10 dark:bg-[#050505]"
              >
                <label for="terminal-command-input" class="shrink-0 text-neutral-600 dark:text-neutral-400">
                  bohr&gt;
                </label>
                <input
                  id="terminal-command-input"
                  class="min-w-0 flex-1 rounded-[2px] border border-[color:var(--bohr-shell-border)] bg-transparent px-3 py-2 text-neutral-900 outline-none transition-colors placeholder:text-neutral-500 focus:border-[var(--bohr-shell-fg)] dark:text-neutral-100 dark:placeholder:text-neutral-500"
                  type="text"
                  name="terminal-command"
                  value={defaultTerminalSample.prompt}
                  spellcheck="false"
                  autocomplete="off"
                />
                <button
                  id="terminal-command-submit"
                  type="submit"
                  class="inline-flex shrink-0 items-center justify-center rounded-[2px] border border-[var(--bohr-shell-fg)] px-4 py-2 uppercase tracking-[0.12em] text-[var(--bohr-shell-fg)] transition-colors hover:bg-[var(--bohr-shell-fg)] hover:text-[var(--bohr-shell-bg)]"
                >
                  Run sample
                </button>
              </form>
            </div>
          </div>

        </div>
      </section>

      <!-- Pillars -->
      <section
        data-gsap-reveal
        class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] -mt-4 w-screen bg-[var(--bohr-shell-bg)] pb-14 pt-12 sm:-mt-5 sm:pb-16 sm:pt-14"
        aria-labelledby="pillars-heading"
      >
        <div class="relative w-full max-w-none px-4 sm:px-5 md:px-6 lg:px-8 xl:px-10">
          <p class="font-[family-name:var(--font-cli)] text-[10px] uppercase tracking-[0.22em] text-neutral-500 sm:text-[11px]">
            - 01 | PILLARS
          </p>
          <div
            class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] lg:items-start lg:gap-16 xl:gap-24"
          >
            <h2
              id="pillars-heading"
              class="font-['Cormorant_Garamond',Georgia,'Times_New_Roman',serif] text-[clamp(1.85rem,4.5vw,3rem)] font-normal italic leading-[1.12] tracking-tight text-[var(--bohr-shell-fg)]"
            >
              Research, not autocomplete.
            </h2>
            <p
              class="font-[family-name:var(--font-cli)] text-[12px] leading-relaxed text-neutral-700 lg:pt-1 lg:text-[13px] dark:text-neutral-300"
            >
              Bohr AI is built for people who write papers, run replications and defend claims. The shell orchestrates
              specialised agents, verifies against sources, and leaves a trail - not a chat log.
            </p>
          </div>

          <!-- Closed grid: full perimeter border + internal dividers -->
          <div
            data-gsap-stagger-group
            class="mt-14 border border-[color:var(--bohr-shell-border)] sm:mt-16"
          >
            <div
              class="grid grid-cols-1 divide-y divide-[color:var(--bohr-shell-border)] bg-neutral-950/[0.03] lg:grid-cols-4 lg:divide-x lg:divide-y-0 dark:bg-black/20"
            >
              {pillars.map((pillar) => (
                <article
                  data-gsap-stagger-item
                  class="flex flex-col px-5 py-9 font-[family-name:var(--font-cli)] sm:px-6 sm:py-10 lg:min-h-[14rem] lg:px-6 xl:px-8"
                >
                  <p class="text-[11px] uppercase tracking-[0.14em] text-neutral-500">{pillar.roman}</p>
                  <p class="mt-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--bohr-shell-fg)] sm:text-[12px]">
                    {pillar.title}
                  </p>
                  <p class="mt-4 text-[12px] leading-relaxed text-neutral-600 sm:text-[13px] dark:text-neutral-400">{pillar.body}</p>
                </article>
              ))}
