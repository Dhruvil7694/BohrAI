---
import Layout from "@/layouts/main.astro"
import DocsChrome from "@/components/DocsChrome.astro"
import { docsSidebarSections } from "@/data/docs-nav"

const highlights = [
  {
    title: "Installation",
    description: "Bootstrap Bohr and configure providers.",
    href: "/docs/getting-started/installation",
  },
  {
    title: "Why Bohr?",
    description: "Versus generic AI writers—grounding, workflows, savings.",
    href: "/docs/getting-started/why-bohr",
  },
  {
    title: "Slash commands",
    description: "Every REPL command in one place.",
    href: "/docs/reference/slash-commands",
  },
  {
    title: "CLI commands",
    description: "Equivalent `bohr …` invocations from the shell.",
    href: "/docs/reference/cli-commands",
  },
] as const
---

<Layout title="Documentation — Bohr AI" description="Guides, workflows, agents, templates, tools, and reference." active="docs">
  <DocsChrome>
    <article class="min-w-0 w-full max-w-none pb-12 lg:pb-16">
      <nav class="docs-breadcrumb mb-8" aria-label="Breadcrumb">
        <span class="text-[var(--bohr-shell-fg)]">Docs</span>
      </nav>

      <header class="mb-12">
        <p class="hub-kicker mb-2">— DOCS · REFERENCE</p>
        <h1 class="docs-page-title mt-6">Docs</h1>
        <p class="docs-page-lede mt-5 max-w-xl">
          Guides and reference for Bohr—including{" "}
          <a
            class="font-medium text-[var(--bohr-shell-fg)] underline decoration-neutral-400 underline-offset-4 transition-colors hover:decoration-neutral-600 dark:decoration-neutral-600 dark:hover:decoration-neutral-400"
            href="/docs/getting-started/why-bohr">why Bohr isn&apos;t a generic paper writer</a
          >
          . For a visual overview, see{" "}
          <a
            class="font-medium text-[var(--bohr-shell-fg)] underline decoration-neutral-400 underline-offset-4 transition-colors hover:decoration-neutral-600 dark:decoration-neutral-600 dark:hover:decoration-neutral-400"
            href="/explore">Explore</a
          >
          {" · "}
          <a
            class="font-medium text-[var(--bohr-shell-fg)] underline decoration-neutral-400 underline-offset-4 transition-colors hover:decoration-neutral-600 dark:decoration-neutral-600 dark:hover:decoration-neutral-400"
            href="/agents">Agents</a
          >
          {" · "}
          <a
            class="font-medium text-[var(--bohr-shell-fg)] underline decoration-neutral-400 underline-offset-4 transition-colors hover:decoration-neutral-600 dark:decoration-neutral-600 dark:hover:decoration-neutral-400"
            href="/workflows">Workflows</a
          >
          {" · "}
          <a
            class="font-medium text-[var(--bohr-shell-fg)] underline decoration-neutral-400 underline-offset-4 transition-colors hover:decoration-neutral-600 dark:decoration-neutral-600 dark:hover:decoration-neutral-400"
            href="/how-it-works">How it works</a
          >.
        </p>
      </header>

      <div class="space-y-12">
        <section aria-labelledby="popular-heading">
          <h2 id="popular-heading" class="docs-hub-section-label">
            Start here
          </h2>
          <ul class="grid list-none gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5 lg:items-stretch">
            {
              highlights.map((h) => (
                <li class="flex min-h-0">
                  <a href={h.href} class="docs-hub-card group w-full min-w-0 no-underline">
                    <span class="docs-hub-card-title">{h.title}</span>
                    <span class="docs-hub-card-desc">{h.description}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="border-t border-border/50 pt-12" aria-labelledby="all-topics-heading">
          <h2 id="all-topics-heading" class="docs-hub-section-label">
            All topics
          </h2>
          <p class="docs-page-lede mb-8 max-w-xl">
            Use the sidebar to jump to a page, or open a section below.
          </p>
          <div class="space-y-10">
            {
              docsSidebarSections.map((section) => (
                <div>
                  <h3 class="docs-topic-group-title">{section.title}</h3>
                  <ul class="grid gap-x-8 gap-y-1 sm:grid-cols-2">
                    {section.items.map((item) => (
                      <li>
                        <a href={`/docs/${item.slug}`} class="docs-hub-link">
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </article>
  </DocsChrome>
</Layout>
