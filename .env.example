# Optional runtime defaults for Bohr AI.
# Provider credentials are read by pi-coding-agent in the usual ways.

BOHR_MODEL=
BOHR_THINKING=medium

# Deployment / distribution overrides
# Runtime installer fallback shown by CLI/node-version guards.
BOHR_INSTALL_PUBLIC_BASE_URL=
BOHR_INSTALL_SCRIPT_URL=
BOHR_INSTALL_PS1_URL=

# Release hosting used by install scripts.
BOHR_RELEASES_LATEST_URL=
BOHR_INSTALL_BASE_URL=
BOHR_REPO_ARCHIVE_BASE_URL=
BOHR_INSTALL_SKILLS_ARCHIVE_URL=

# Website build-time deployment URLs (Astro reads PUBLIC_* at build time).
PUBLIC_BOHR_SITE_URL=
PUBLIC_BOHR_GITHUB_REPO_URL=
PUBLIC_BOHR_INSTALL_BASE_URL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
CEREBRAS_API_KEY=
HF_TOKEN=
OPENCODE_API_KEY=
AI_GATEWAY_API_KEY=
AZURE_OPENAI_API_KEY=

RUNPOD_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Research Paper Search APIs (all free!)
# ArXiv - No API key needed (free)
ARXIV_API_URL=http://export.arxiv.org/api/query

# Semantic Scholar - Optional API key for higher rate limits
# Free tier: 100 requests/5 minutes, With API key: 5000 requests/5 minutes
# Get key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed - No API key needed (free)
PUBMED_API_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils/

# Google Scholar via SerpAPI - Optional
# Free tier: 100 searches/month, Get key at: https://serpapi.com/
SERPAPI_KEY=

# Paper Generator Configuration
WORKSPACE_ROOT=.
MAX_TOKENS_PER_SESSION=100000
# When false, Pi subagent caveman defaults to "lite". When true, use CAVEMAN_MODE_DEFAULT (lite|full|ultra).
ENABLE_TOKEN_OPTIMIZATION=true
CAVEMAN_MODE_DEFAULT=ultra
EXPORT_DIR=./exports
SESSION_DIR=./.paper-gen-state
MAX_CONCURRENT_AGENTS=4
MAX_ITERATIONS=4

# Quality Gate Thresholds
MIN_EVIDENCE_SOURCES=10
MIN_COVERAGE_PERCENT=80
MIN_RECENT_SOURCES_PERCENT=30
MIN_CONFIDENCE_SCORE=0.85
