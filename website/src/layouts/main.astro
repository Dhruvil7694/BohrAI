---
import "@/styles/global.css"
import { ViewTransitions } from "astro:transitions"
import Navbar from "../components/Navbar.astro"

interface Props {
  title?: string
  description?: string
  active?: "home" | "docs" | "explore"
  /** Terminal-style shell (homepage). Other pages use default theme tokens. */
  shell?: "default" | "cli"
}

const {
  title = "Bohr AI - Private AI research system",
  description = "A private AI research system that helps teams discover, analyze, and synthesize technical knowledge.",
  active = "home",
  shell = "default",
} = Astro.props
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400&family=VT323&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
    <script is:inline>
      ;(function () {
        const theme = localStorage.getItem("theme")
        if (theme === "dark" || (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark")
        } else {
          document.documentElement.classList.remove("dark")
        }
      })()
    </script>
  </head>
  <body
    class:list={[
      "flex min-h-screen flex-col antialiased",
      shell === "cli"
        ? "overflow-x-clip bg-[#050505] text-[#d4d4d4] selection:bg-[#e5e5e5] selection:text-[#0a0a0a]"
        : "bg-background text-foreground",
    ]}
  >
    <Navbar active={active} variant="cli" />

    <main
      class:list={[
        "flex min-h-0 w-full min-w-0 flex-1 flex-col overflow-x-hidden",
        shell === "cli"
          ? "pt-[5.25rem] font-[family-name:var(--font-cli)] text-[#d4d4d4] sm:pt-[4.75rem] md:pt-14"
          : "pt-[5.25rem] sm:pt-[4.75rem] md:pt-14",
      ]}
    >
      <slot />
    </main>
  </body>
</html>
