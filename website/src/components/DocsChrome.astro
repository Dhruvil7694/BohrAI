---
import { docsSidebarSections } from "@/data/docs-nav"

interface Props {
  /** Active doc slug (`entry.slug`). Omit on `/docs` hub — no nav item marked active. */
  currentSlug?: string | null
}

const { currentSlug = null } = Astro.props

const slugInNav =
  currentSlug != null &&
  docsSidebarSections.some((s) => s.items.some((item) => item.slug === currentSlug))

const navSections = docsSidebarSections.map((section) => {
  const containsActive =
    currentSlug != null && section.items.some((item) => item.slug === currentSlug)
  const defaultOpen =
    currentSlug == null
      ? section.title === "Getting started"
      : containsActive || (!slugInNav && section.title === "Getting started")
  return { section, open: defaultOpen }
})
---

<div class="docs-page-gutter-x pb-8 pt-2 sm:pt-3 lg:pb-5 lg:pt-0">
    <aside
      id="docs-sidebar"
      class:list={[
        "fixed inset-y-0 left-0 z-50 flex w-[min(21rem,93vw)] -translate-x-full flex-col overflow-y-auto border-r border-border/80 bg-background px-4 pb-10 pt-16 shadow-xl transition-[transform,box-shadow] duration-200 ease-out",
        "lg:bottom-5 lg:left-4 lg:top-[calc(3.5rem+10px)] lg:z-30 lg:w-[15.5rem] lg:translate-x-0 lg:overflow-y-auto lg:rounded-2xl lg:border lg:border-border/40 lg:bg-card/70 lg:px-4 lg:pb-5 lg:pt-4 lg:shadow-[0_16px_48px_-8px_rgba(0,0,0,0.55)] lg:ring-1 lg:ring-border/35 lg:backdrop-blur-md",
        "xl:left-5 xl:w-[17.5rem] 2xl:left-6 2xl:w-80",
      ]}
      aria-label="Documentation navigation"
    >
      <div class="mb-4 border-b border-border/50 pb-3 lg:mb-4 lg:border-border/35 lg:pb-3">
        <a
          href="/docs"
          class:list={[
            "text-[13px] font-semibold tracking-tight transition-colors hover:text-foreground",
            Astro.url.pathname === "/docs" ? "text-foreground" : "text-muted-foreground",
          ]}
        >
          Documentation
        </a>
        <p class="mt-0.5 text-[11px] leading-snug text-muted-foreground/90">Guides &amp; reference</p>
      </div>

      <nav class="flex flex-1 flex-col gap-0">
        {
          navSections.map(({ section, open }) => (
            <details class="docs-nav-details" name="docs-nav" open={open}>
              <summary class="docs-nav-summary">
                <span class="min-w-0 flex-1 text-left leading-snug">{section.title}</span>
                <svg class="docs-nav-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <ul class="mt-1 space-y-px border-l border-border/40 pl-2.5 ml-2">
                {section.items.map((item) => (
                  <li>
                    <a
                      href={`/docs/${item.slug}`}
                      class:list={[
                        "docs-layout-navlink",
                        currentSlug != null && currentSlug === item.slug && "docs-layout-navlink-active",
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </nav>
    </aside>

    <div
      id="docs-sidebar-overlay"
      class="fixed inset-0 z-40 hidden bg-black/40 backdrop-blur-[2px] lg:hidden"
      aria-hidden="true"
    />

    <!-- Align with fixed sidebar top (main is only pt-14 = 3.5rem; sidebar adds +10px float gap) -->
    <div class="flex flex-col lg:mt-[10px] lg:flex-row lg:items-stretch lg:gap-2.5">
      <div
        class="hidden shrink-0 lg:block lg:w-[15.5rem] xl:w-[17.5rem] 2xl:w-80"
        aria-hidden="true"
      />
      <div
        class="min-w-0 flex-1 lg:flex lg:min-h-0 lg:flex-col lg:h-[calc(100vh-3.5rem-10px-1.25rem)] lg:max-h-[calc(100vh-3.5rem-10px-1.25rem)]"
      >
        <div class="docs-main-panel">
          <div class="docs-main-scroll">
            <slot />
          </div>
        </div>
      </div>
    </div>

    <button
      id="docs-mobile-open"
      type="button"
      class="fixed bottom-5 right-5 z-30 flex h-11 w-11 items-center justify-center rounded-full border border-border/80 bg-background/95 text-foreground shadow-md backdrop-blur-sm transition hover:bg-muted/60 lg:hidden"
      aria-controls="docs-sidebar"
      aria-expanded="false"
      aria-label="Open navigation menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
</div>

<script is:inline>
  ;(function () {
    function init() {
      var sidebar = document.getElementById("docs-sidebar")
      var overlay = document.getElementById("docs-sidebar-overlay")
      var openBtn = document.getElementById("docs-mobile-open")

      function setOpen(open) {
        if (!sidebar || !overlay || !openBtn) return
        var mobile = window.matchMedia("(max-width: 1023px)").matches
        if (!mobile) {
          sidebar.classList.remove("-translate-x-full")
          sidebar.classList.remove("docs-sidebar-open")
          overlay.classList.add("hidden")
          document.body.classList.remove("overflow-hidden")
          openBtn.setAttribute("aria-expanded", "false")
          openBtn.setAttribute("aria-label", "Open navigation menu")
          return
        }
        if (open) {
          sidebar.classList.remove("-translate-x-full")
          sidebar.classList.add("docs-sidebar-open")
          overlay.classList.remove("hidden")
          document.body.classList.add("overflow-hidden")
          openBtn.setAttribute("aria-expanded", "true")
          openBtn.setAttribute("aria-label", "Close navigation menu")
        } else {
          sidebar.classList.add("-translate-x-full")
          sidebar.classList.remove("docs-sidebar-open")
          overlay.classList.add("hidden")
          document.body.classList.remove("overflow-hidden")
          openBtn.setAttribute("aria-expanded", "false")
          openBtn.setAttribute("aria-label", "Open navigation menu")
        }
      }

      function close() {
        setOpen(false)
      }

      function toggle() {
        if (!overlay) return
        var closed = overlay.classList.contains("hidden")
        setOpen(closed)
      }

      if (openBtn && sidebar && overlay && !openBtn.dataset.bound) {
        openBtn.dataset.bound = "true"
        openBtn.addEventListener("click", toggle)
        overlay.addEventListener("click", close)
        sidebar.querySelectorAll("a").forEach(function (a) {
          a.addEventListener("click", function () {
            if (window.matchMedia("(max-width: 1023px)").matches) close()
          })
        })
      }

      document.querySelectorAll(".prose pre").forEach(function (pre) {
        if (pre.querySelector(".copy-code")) return
        var copyBtn = document.createElement("button")
        copyBtn.className = "copy-code"
        copyBtn.setAttribute("aria-label", "Copy code")
        copyBtn.innerHTML =
          '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
        pre.appendChild(copyBtn)
        copyBtn.addEventListener("click", function () {
          var code = pre.querySelector("code")
          var text = code ? code.textContent : pre.textContent
          navigator.clipboard.writeText(text)
          copyBtn.innerHTML =
            '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>'
          setTimeout(function () {
            copyBtn.innerHTML =
              '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
          }, 2000)
        })
      })

      window.addEventListener(
        "resize",
        function () {
          if (window.matchMedia("(min-width: 1024px)").matches) close()
        },
        { passive: true }
      )
    }
    init()
    document.addEventListener("astro:after-swap", init)
  })()
</script>
