---
import Layout from "@/layouts/main.astro"

const tiles = [
  {
    title: "Agents",
    description: "Every bundled agent, what it does, and which workflows call it.",
    href: "/agents",
    hint: "researcher · reviewer · writer · …",
  },
  {
    title: "Workflows",
    description: "Slash-command pipelines from /deepresearch to /iterate — pick by outcome.",
    href: "/workflows",
    hint: "/lit · /paper · /audit · …",
  },
  {
    title: "Process",
    description: "End-to-end flow: install → REPL → orchestration → artifacts, with diagrams.",
    href: "/how-it-works",
    hint: "step-by-step · diagrams",
  },
  {
    title: "Documentation",
    description: "Full prose docs: setup, templates, tools, CLI & slash reference.",
    href: "/docs",
    hint: "guides & reference",
  },
  {
    title: "Slash commands",
    description: "Alphabetical command reference for the REPL.",
    href: "/docs/reference/slash-commands",
    hint: "/help in session",
  },
  {
    title: "Installation",
    description: "Bootstrap Bohr on your machine and configure keys.",
    href: "/docs/getting-started/installation",
    hint: "quick start",
  },
] as const
---

<Layout title="Explore Bohr AI" description="Agents, workflows, process maps, and docs — organized for fast navigation." active="explore">
  <div class="page-gutter-x pb-20 pt-10">
    <header class="mb-12 w-full max-w-none">
      <p class="hub-kicker mb-2">Start here</p>
      <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Explore</h1>
      <p class="mt-3 text-lg text-muted-foreground">
        Choose how you want to learn Bohr: browse <strong class="text-foreground">agents</strong> and{" "}
        <strong class="text-foreground">workflows</strong>, read the <strong class="text-foreground">process</strong>{" "}
        overview with diagrams, or jump into full <strong class="text-foreground">documentation</strong>.
      </p>
    </header>

    <ul class="grid gap-4 sm:grid-cols-2">
      {
        tiles.map((t) => (
          <li>
            <a href={t.href} class="hub-card group h-full no-underline">
              <span class="text-lg font-semibold text-foreground group-hover:text-primary">{t.title}</span>
              <span class="text-sm leading-relaxed text-muted-foreground">{t.description}</span>
              <span class="mt-auto font-mono text-xs text-primary/90">{t.hint}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
